rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isSignedIn() {
      return request.auth != null;
    }

    // All roles live in the unified users collection.
    function userRole() {
      return isSignedIn()
        && exists(/databases/$(database)/documents/users/$(request.auth.uid))
        ? get(/databases/$(database)/documents/users/$(request.auth.uid)).data.get('role', 'user')
        : 'guest';
    }

    function isAdmin() {
      return userRole() == 'admin';
    }

    function isSuperAdmin() {
      return userRole() == 'super_admin';
    }

    function isPrivileged() {
      return isAdmin() || isSuperAdmin();
    }

    function canUseCommunityChat() {
      return isSignedIn()
        && (
          isAdmin()
          || (
            exists(/databases/$(database)/documents/users/$(request.auth.uid))
            && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.status == 'active'
          )
        );
    }

    match /users/{userId} {
      allow read: if isSignedIn() && (request.auth.uid == userId || isPrivileged());

      // Privileged users can write any field (ban, block, create admin, etc.).
      allow write: if isPrivileged();

      // Regular users may only create or update their own document and
      // must NEVER touch the security-sensitive status / banUntil fields.
      allow create: if isSignedIn()
        && request.auth.uid == userId
        && (!('status' in request.resource.data) || request.resource.data.status == 'active')
        && (!('banUntil' in request.resource.data) || request.resource.data.banUntil == null);

      allow update: if isSignedIn()
        && request.auth.uid == userId
        && (!request.resource.data.diff(resource.data).affectedKeys().hasAny(['status', 'banUntil']));
    }

    match /users/{userId}/favorites/{journeyId} {
      allow read, write: if isSignedIn() && request.auth.uid == userId;
    }

    // Transport data collections
    match /journeys/{journeyId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    match /stations/{stationId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    match /routes/{routeId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    match /route_stops/{docId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    match /trips/{tripId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    match /tariffs/{tariffId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    match /transport_types/{typeId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    match /operators/{operatorId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    match /bus_services/{serviceId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    match /notifications/{notifId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    match /community_messages/{messageId} {
      allow read: if canUseCommunityChat();

      allow create: if isSignedIn()
        && request.resource.data.uid == request.auth.uid
        && request.resource.data.keys().hasOnly([
          'uid',
          'username',
          'avatarId',
          'text',
          'timestamp',
          'replyTo'
        ])
        && request.resource.data.username is string
        && request.resource.data.username.size() > 0
        && request.resource.data.username.size() <= 64
        && request.resource.data.avatarId is string
        && request.resource.data.avatarId.size() > 0
        && request.resource.data.avatarId.size() <= 64
        && request.resource.data.text is string
        && request.resource.data.text.size() > 0
        && request.resource.data.text.size() <= 1000
        && request.resource.data.timestamp is timestamp
        && (
          !('replyTo' in request.resource.data)
          || (
            request.resource.data.replyTo is map
            && request.resource.data.replyTo.keys().hasOnly(['messageId', 'text', 'username'])
            && request.resource.data.replyTo.messageId is string
            && request.resource.data.replyTo.messageId.size() > 0
            && request.resource.data.replyTo.text is string
            && request.resource.data.replyTo.text.size() <= 120
            && request.resource.data.replyTo.username is string
            && request.resource.data.replyTo.username.size() > 0
            && request.resource.data.replyTo.username.size() <= 64
          )
        );

      allow update, delete: if isSignedIn()
        && (resource.data.uid == request.auth.uid || isAdmin());
    }

    match /taxi_collectif_routes/{routeId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    // Username reservations — created at signup to enforce uniqueness across
    // pending (unverified) and confirmed accounts.
    // Users may only create a reservation for their own UID. Admins can delete
    // stale reservations if needed.
    match /usernames/{username} {
      allow read: if true;
      allow create: if isSignedIn()
        && request.resource.data.uid == request.auth.uid;
      // Allow the owner to update (e.g., drop reservedAt on first verified login).
      allow update: if isSignedIn()
        && resource.data.uid == request.auth.uid
        && request.resource.data.uid == request.auth.uid;
      allow delete: if isAdmin();
    }

    // Legacy admins collection — kept for backward-compat during migration.
    // New accounts write to users collection only.
    match /admins/{adminId} {
      allow read: if isSignedIn();
      allow write: if isSuperAdmin();
    }

    match /activity_logs/{logId} {
      allow create: if isSignedIn();
      allow read: if isSuperAdmin();
      allow update, delete: if false;
    }

    match /system_stats/{statsId} {
      allow read, write: if isSuperAdmin();
    }

    match /app_sessions/{sessionId} {
      allow read: if isSuperAdmin();
      allow create, update: if isSignedIn() && request.auth.uid == request.resource.data.userId;
      allow delete: if isSuperAdmin();
    }

    // Queue for Firebase Trigger Email extension (firestore-send-email).
    // Super admin writes notification jobs; clients never read queued emails.
    match /mail_queue/{docId} {
      allow create: if isSuperAdmin();
      allow read, update, delete: if false;
    }

    // Matricule → real Auth email mapping for promoted admins.
    // Public read: the login screen needs this before the user is authenticated.
    // Write restricted to privileged roles only.
    match /admin_login_lookup/{matricule} {
      allow read: if true;
      allow write: if isPrivileged();
    }
  }
}
