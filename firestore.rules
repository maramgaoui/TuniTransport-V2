rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isSignedIn() {
      return request.auth != null;
    }

    // Explicit role checks — avoids ternary precedence issues that can
    // cause PERMISSION_DENIED on collection queries.
    function isLegacyAdmin() {
      return request.auth != null
        && exists(/databases/$(database)/documents/admins/$(request.auth.uid))
        && get(/databases/$(database)/documents/admins/$(request.auth.uid)).data.get('role', '') in [
             'admin', 'admin_bus', 'admin_metro', 'admin_taxi_collectifs', 'admin_louage_train'
           ];
    }

    function isLegacySuperAdmin() {
      return request.auth != null
        && exists(/databases/$(database)/documents/admins/$(request.auth.uid))
        && get(/databases/$(database)/documents/admins/$(request.auth.uid)).data.get('role', '') == 'super_admin';
    }

    // Returns true if the caller's users document marks them as active.
    // Accepts both status:'active' (new format) and isActive:true (legacy
    // bootstrap documents that were created before status was standardised).
    function callerIsActive() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data.get('status', '') == 'active'
          || get(/databases/$(database)/documents/users/$(request.auth.uid)).data.get('isActive', false) == true;
    }

    function isAdmin() {
      return request.auth != null
        && (
          (
            exists(/databases/$(database)/documents/users/$(request.auth.uid))
            && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.get('role', '') in [
                 'admin', 'admin_bus', 'admin_metro', 'admin_taxi_collectifs', 'admin_louage_train'
               ]
            && callerIsActive()
          )
          || isLegacyAdmin()
        );
    }

    function isSuperAdmin() {
      return request.auth != null
        && (
          (
            exists(/databases/$(database)/documents/users/$(request.auth.uid))
            && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.get('role', '') == 'super_admin'
            && callerIsActive()
          )
          || isLegacySuperAdmin()
        );
    }

    function isPrivileged() {
      return isAdmin() || isSuperAdmin();
    }

    function canUseCommunityChat() {
      return isSignedIn()
        && (
          isAdmin()
          || (
            exists(/databases/$(database)/documents/users/$(request.auth.uid))
            && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.get('status', '') == 'active'
          )
        );
    }

    match /users/{userId} {
      // Single-document reads: own doc OR privileged.
      allow get: if isSignedIn() && (request.auth.uid == userId || isPrivileged());
      // Collection queries: privileged users have no limit; authenticated users
      // are restricted to limit-1 queries (used for username uniqueness checks).
      allow list: if isSignedIn() && (isPrivileged() || request.query.limit <= 1);

      // Privileged users can write, but admins are limited to regular users.
      // Uses request.resource.data (new document state) instead of resource.data
      // because Firestore evaluates set/update operations as CREATE in rules,
      // making resource null. Checking the resulting document state is equivalent:
      // if role stays 'user' and no adminType/permissions are granted, the write is safe.
      allow write: if
        isSuperAdmin()
        || (
          isAdmin()
          && request.resource.data.get('role', 'user') == 'user'
          && request.resource.data.get('adminType', null) == null
          && (
            !('permissions' in request.resource.data)
            || request.resource.data.permissions.size() == 0
          )
        )
        || (
          request.auth.uid == userId
          && resource.exists
          && !request.resource.data.diff(resource.data).affectedKeys().hasAny([
            'status',
            'banUntil',
            'role',
            'adminType',
            'permissions',
          ])
        )
        // User may self-clear their own expired ban (AuthController auto-reactivation).
        || (
          request.auth.uid == userId
          && resource.exists
          && resource.data.get('status', '') == 'banned'
          && resource.data.get('banUntil', null) is timestamp
          && resource.data.banUntil <= request.time
          && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['status', 'banUntil'])
          && request.resource.data.status == 'active'
          && request.resource.data.banUntil == null
        )
        // Allow users to set only their fcmToken (for push notifications) even on non-existent docs
        || (
          request.auth.uid == userId
          && (
            (!resource.exists && request.resource.data.keys().hasOnly(['fcmToken']))
            || (resource.exists && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['fcmToken']))
          )
          && request.resource.data.fcmToken is string
        );

      // Regular users may only create or update their own document and
      // must NEVER touch the security-sensitive status / banUntil fields.
      allow create: if isSignedIn()
        && request.auth.uid == userId
        && (!('status' in request.resource.data) || request.resource.data.status == 'active')
        && (!('banUntil' in request.resource.data) || request.resource.data.banUntil == null)
        && (
          (!('role' in request.resource.data) || request.resource.data.role == 'user')
          || (
            exists(/databases/$(database)/documents/admins/$(request.auth.uid))
            && get(/databases/$(database)/documents/admins/$(request.auth.uid)).data.get('role', '') in ['admin', 'super_admin']
          )
        );

      allow update: if isSignedIn()
        && request.auth.uid == userId
        && (!request.resource.data.diff(resource.data).affectedKeys().hasAny(['status', 'banUntil', 'role', 'adminType', 'permissions']));
    }

    match /users/{userId}/favorites/{journeyId} {
      allow read, write: if isSignedIn() && request.auth.uid == userId;
    }

    match /users/{userId}/notifications/{notifId} {
      allow read: if isSignedIn() && request.auth.uid == userId;
      allow write: if isSignedIn() && (request.auth.uid == userId || isPrivileged());
    }

    // Transport data collections
    match /stations/{stationId} {
      allow read: if isSignedIn();
      allow write: if isSuperAdmin();
    }

    match /routes/{routeId} {
      allow read: if isSignedIn();
      allow write: if isPrivileged();
    }

    match /route_stops/{docId} {
      allow read: if isSignedIn();
      allow write: if isPrivileged();
    }

    match /trips/{tripId} {
      allow read: if isSignedIn();
      allow write: if isPrivileged();
    }

    match /tariffs/{tariffId} {
      allow read: if isSignedIn();
      allow write: if isPrivileged();
    }

    match /bus_services/{serviceId} {
      allow read: if isSignedIn();
      allow write: if isPrivileged();
    }

    match /notifications/{notifId} {
      allow read: if isSignedIn();
      allow write: if isPrivileged();
    }

    match /audit_logs/{logId} {
      allow create: if isPrivileged()
        && request.resource.data.keys().hasOnly([
          'action',
          'targetUid',
          'targetEmail',
          'actorUid',
          'actorEmail',
          'details',
          'createdAt',
        ])
        && request.resource.data.action is string
        && request.resource.data.targetUid is string
        && request.resource.data.targetEmail is string
        && request.resource.data.actorUid is string
        && request.resource.data.actorEmail is string
        && request.resource.data.details is map
        && request.resource.data.createdAt is timestamp;
      allow read: if isSuperAdmin();
      allow update, delete: if false;
    }

    match /community_messages/{messageId} {
      allow read: if canUseCommunityChat();

      allow create: if isSignedIn()
        && callerIsActive()
        && request.resource.data.uid == request.auth.uid
        && request.resource.data.keys().hasOnly([
          'uid',
          'username',
          'avatarId',
          'text',
          'timestamp',
          'replyTo'
        ])
        && request.resource.data.username is string
        && request.resource.data.username.size() > 0
        && request.resource.data.username.size() <= 64
        && request.resource.data.avatarId is string
        && request.resource.data.avatarId.size() > 0
        && request.resource.data.avatarId.size() <= 64
        && request.resource.data.text is string
        && request.resource.data.text.size() > 0
        && request.resource.data.text.size() <= 1000
        && request.resource.data.timestamp is timestamp
        && (
          !('replyTo' in request.resource.data)
          || (
            request.resource.data.replyTo is map
            && request.resource.data.replyTo.keys().hasOnly(['messageId', 'text', 'username'])
            && request.resource.data.replyTo.messageId is string
            && request.resource.data.replyTo.messageId.size() > 0
            && request.resource.data.replyTo.text is string
            && request.resource.data.replyTo.text.size() <= 120
            && request.resource.data.replyTo.username is string
            && request.resource.data.replyTo.username.size() > 0
            && request.resource.data.replyTo.username.size() <= 64
          )
        );

      allow update: if isSignedIn()
        && (
          (
            resource.data.uid == request.auth.uid
            && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['text'])
          )
          || isPrivileged()
        );
      allow delete: if isSignedIn()
        && (resource.data.uid == request.auth.uid || isPrivileged());
    }

    match /taxi_collectif_routes/{routeId} {
      allow read: if isSignedIn();
      allow write: if isPrivileged();
    }

    // Legacy admins collection — kept for backward-compat during migration.
    match /admins/{adminId} {
      allow read: if isPrivileged() || request.auth.uid == adminId;
      allow write: if isSuperAdmin();
    }

    match /activity_logs/{logId} {
      allow create: if isSignedIn()
        && request.resource.data.keys().hasOnly([
          'userId', 'email', 'action', 'timestamp', 'metadata'
        ])
        && request.resource.data.userId  is string
        && request.resource.data.email   is string
        && request.resource.data.action  is string
        && request.resource.data.timestamp is timestamp
        && request.resource.data.metadata  is map
        && request.resource.data.userId == request.auth.uid;
      allow read: if isSuperAdmin();
      allow update, delete: if false;
    }

    match /system_stats/{statsId} {
      allow read, write: if isSuperAdmin();
    }

    match /app_sessions/{sessionId} {
      allow read: if isSuperAdmin();
      allow create, update: if isSignedIn() && request.auth.uid == request.resource.data.userId;
      allow delete: if isSuperAdmin();
    }

    // Queue for Firebase Trigger Email extension (firestore-send-email).
    match /mail_queue/{docId} {
      allow create: if isPrivileged();
      allow read, update, delete: if false;
    }

    // ── Rating system ──────────────────────────────────────────────────────────

    match /ratings/{ratingId} {
      // Users can only read their own ratings.
      allow read: if isSignedIn() && resource.data.uid == request.auth.uid;

      // Create: must own the doc, rating must be 1–5 integer.
      allow create: if isSignedIn()
        && request.resource.data.uid == request.auth.uid
        && request.resource.data.rating is int
        && request.resource.data.rating >= 1
        && request.resource.data.rating <= 5
        && request.resource.data.routeKey is string
        && request.resource.data.routeKey.size() > 0;

      // Update: same owner, same constraints.
      allow update: if isSignedIn()
        && resource.data.uid == request.auth.uid
        && request.resource.data.uid == request.auth.uid
        && request.resource.data.rating is int
        && request.resource.data.rating >= 1
        && request.resource.data.rating <= 5;

      // Users may delete their own rating.
      allow delete: if isSignedIn() && resource.data.uid == request.auth.uid;
    }

    match /route_stats/{routeKey} {
      // Any signed-in user can read aggregates (needed for recommendations).
      allow read: if isSignedIn();

      // Clients write via RatingService transactions.
      // Enforce schema, value ranges, and internal consistency so a rogue
      // client cannot inflate averageRating without matching sum/total.
      allow create, update: if isSignedIn()
        && request.resource.data.keys().hasOnly([
          'routeKey', 'transportType', 'fromStationId', 'toStationId',
          'averageRating', 'totalRatings', 'sumRatings', 'updatedAt'
        ])
        && request.resource.data.averageRating is number
        && request.resource.data.averageRating >= 0
        && request.resource.data.averageRating <= 5
        && request.resource.data.totalRatings is int
        && request.resource.data.totalRatings >= 0
        && request.resource.data.sumRatings is number
        && request.resource.data.sumRatings >= 0
        && (
          request.resource.data.totalRatings == 0
          || (
            request.resource.data.averageRating * request.resource.data.totalRatings
              >= request.resource.data.sumRatings - 0.5
            && request.resource.data.averageRating * request.resource.data.totalRatings
              <= request.resource.data.sumRatings + 0.5
          )
        );

      allow delete: if isSuperAdmin();
    }

    // Matricule → real Auth email mapping for promoted admins.
    // get (single-doc by matricule ID) requires authentication so that only
    // signed-in users can resolve a matricule → email (prevents unauthenticated
    // enumeration of admin email addresses).
    // list is blocked to prevent bulk enumeration of all admin matricules.
    match /admin_login_lookup/{matricule} {
      allow get: if request.auth != null;
      allow list: if isSuperAdmin();
      allow write: if isSuperAdmin();
    }

    match /super_admin_stats/{doc} {
      allow read, write: if isSuperAdmin();
    }
  }
}
