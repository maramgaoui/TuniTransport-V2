rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isSignedIn() {
      return request.auth != null;
    }

    // Explicit role checks — avoids ternary precedence issues that can
    // cause PERMISSION_DENIED on collection queries.
    function isAdmin() {
      return request.auth != null
        && exists(/databases/$(database)/documents/users/$(request.auth.uid))
        && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.get('role', '') == 'admin';
    }

    function isSuperAdmin() {
      return request.auth != null
        && exists(/databases/$(database)/documents/users/$(request.auth.uid))
        && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.get('role', '') == 'super_admin';
    }

    function isPrivileged() {
      return isAdmin() || isSuperAdmin();
    }

    function canUseCommunityChat() {
      return isSignedIn()
        && (
          isAdmin()
          || (
            exists(/databases/$(database)/documents/users/$(request.auth.uid))
            && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.get('status', '') == 'active'
          )
        );
    }

    match /users/{userId} {
      // Single-document reads: own doc OR privileged.
      // Collection queries: privileged users can query all (isPrivileged() is
      // independent of userId so Firestore allows the list operation).
      allow read: if isSignedIn() && (request.auth.uid == userId || isPrivileged());

      // Privileged users can write any field (ban, block, promote admin, etc.).
      allow write: if isPrivileged();

      // Regular users may only create or update their own document and
      // must NEVER touch the security-sensitive status / banUntil fields.
      allow create: if isSignedIn()
        && request.auth.uid == userId
        && (!('status' in request.resource.data) || request.resource.data.status == 'active')
        && (!('banUntil' in request.resource.data) || request.resource.data.banUntil == null)
        && (!('role' in request.resource.data) || request.resource.data.role == 'user');

      allow update: if isSignedIn()
        && request.auth.uid == userId
        && (!request.resource.data.diff(resource.data).affectedKeys().hasAny(['status', 'banUntil', 'role', 'adminType', 'permissions']));
    }

    match /users/{userId}/favorites/{journeyId} {
      allow read, write: if isSignedIn() && request.auth.uid == userId;
    }

    // Transport data collections
    match /journeys/{journeyId} {
      allow read: if isSignedIn();
      allow write: if isPrivileged();
    }

    match /stations/{stationId} {
      allow read: if isSignedIn();
      allow write: if isPrivileged();
    }

    match /routes/{routeId} {
      allow read: if isSignedIn();
      allow write: if isPrivileged();
    }

    match /route_stops/{docId} {
      allow read: if isSignedIn();
      allow write: if isPrivileged();
    }

    match /trips/{tripId} {
      allow read: if isSignedIn();
      allow write: if isPrivileged();
    }

    match /tariffs/{tariffId} {
      allow read: if isSignedIn();
      allow write: if isPrivileged();
    }

    match /transport_types/{typeId} {
      allow read: if isSignedIn();
      allow write: if isPrivileged();
    }

    match /operators/{operatorId} {
      allow read: if isSignedIn();
      allow write: if isPrivileged();
    }

    match /bus_services/{serviceId} {
      allow read: if isSignedIn();
      allow write: if isPrivileged();
    }

    match /notifications/{notifId} {
      allow read: if isSignedIn();
      allow write: if isPrivileged();
    }

    match /community_messages/{messageId} {
      allow read: if canUseCommunityChat();

      allow create: if isSignedIn()
        && request.resource.data.uid == request.auth.uid
        && request.resource.data.keys().hasOnly([
          'uid',
          'username',
          'avatarId',
          'text',
          'timestamp',
          'replyTo'
        ])
        && request.resource.data.username is string
        && request.resource.data.username.size() > 0
        && request.resource.data.username.size() <= 64
        && request.resource.data.avatarId is string
        && request.resource.data.avatarId.size() > 0
        && request.resource.data.avatarId.size() <= 64
        && request.resource.data.text is string
        && request.resource.data.text.size() > 0
        && request.resource.data.text.size() <= 1000
        && request.resource.data.timestamp is timestamp
        && (
          !('replyTo' in request.resource.data)
          || (
            request.resource.data.replyTo is map
            && request.resource.data.replyTo.keys().hasOnly(['messageId', 'text', 'username'])
            && request.resource.data.replyTo.messageId is string
            && request.resource.data.replyTo.messageId.size() > 0
            && request.resource.data.replyTo.text is string
            && request.resource.data.replyTo.text.size() <= 120
            && request.resource.data.replyTo.username is string
            && request.resource.data.replyTo.username.size() > 0
            && request.resource.data.replyTo.username.size() <= 64
          )
        );

      allow update, delete: if isSignedIn()
        && (resource.data.uid == request.auth.uid || isAdmin());
    }

    match /taxi_collectif_routes/{routeId} {
      allow read: if isSignedIn();
      allow write: if isPrivileged();
    }

    match /usernames/{username} {
      allow read: if true;
      allow create: if isSignedIn()
        && request.resource.data.uid == request.auth.uid;
      allow update: if isSignedIn()
        && resource.data.uid == request.auth.uid
        && request.resource.data.uid == request.auth.uid;
      allow delete: if isPrivileged();
    }

    // Legacy admins collection — kept for backward-compat during migration.
    match /admins/{adminId} {
      allow read: if isSignedIn();
      allow write: if isSuperAdmin();
    }

    match /activity_logs/{logId} {
      allow create: if isSignedIn();
      allow read: if isSuperAdmin();
      allow update, delete: if false;
    }

    match /system_stats/{statsId} {
      allow read, write: if isSuperAdmin();
    }

    match /app_sessions/{sessionId} {
      allow read: if isSuperAdmin();
      allow create, update: if isSignedIn() && request.auth.uid == request.resource.data.userId;
      allow delete: if isSuperAdmin();
    }

    // Queue for Firebase Trigger Email extension (firestore-send-email).
    match /mail_queue/{docId} {
      allow create: if isPrivileged();
      allow read, update, delete: if false;
    }

    // Matricule → real Auth email mapping for promoted admins.
    // Public read: the login screen needs this before the user is authenticated.
    match /admin_login_lookup/{matricule} {
      allow read: if true;
      allow write: if isPrivileged();
    }
  }
}
